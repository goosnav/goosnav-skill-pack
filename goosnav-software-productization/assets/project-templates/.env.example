# Safe development placeholders only. Never commit a real .env file.
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_DATA_DIR=
APP_WORKSPACE_DIR=

# Optional development-only provider key. At runtime the app stores the key
# in its app-data config store (edited from the GUI settings), not this file.
AI_PROVIDER_API_KEY=

# M3 hosted values are added only when M3 begins.
